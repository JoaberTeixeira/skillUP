<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkillUP - home</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('cabecario', { titulo: 'SkillUP - sistema de aprendizagem' }) %>

    <div class="main-container">
        <h1>Bem-vindo ao Sistema Administrativo do Time</h1>
