<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Jogo</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../cabecario', { titulo: 'WikiOsasco - Sistema Administrativo' }) %>

    <div class="form-container">
        <form action="/admin/jogo/edt/<%= jogo._id %>" method="post">
            <h3>Editar Jogo</h3>

            <label for="adversario">Adversário:</label>
            <input type="text" id="adversario" name="adversario" value="<%= jogo.adversario %>" required>

            <label for="data">Data:</label>
            <input type="date" id="data" name="data" value="<%= jogo.data.toISOString().substring(0, 10) %>" required>

            <label for="local">Local:</label>
            <input type="text" id="local" name="local" value="<%= jogo.local %>" required>

            <label for="resultado">Resultado:</label>
            <input type="text" id="resultado" name="resultado" value="<%= jogo.resultado || '' %>">

            <button type="submit">Atualizar</button>
        </form>
        <a class="back-link" href="/admin/jogo/lst">Voltar para a lista</a>
    </div>

</body>

</html>
