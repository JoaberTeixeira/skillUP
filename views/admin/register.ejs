<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastrar Usuário</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('cabecario', { titulo: 'Cadastro de Usuário' }) %>

    <div class="form-container">
        <h1>Cadastrar Novo Usuário</h1>

        <% if (error) { %>
            <p class="login-error"><%= error %></p>
        <% } %>

        <% if (success) { %>
            <p class="success-msg"><%= success %></p>
        <% } %>

        <form method="post" action="/register">
            <label for="nome">Nome</label>
            <input id="nome" name="nome" type="text" required value="<%= form.nome || '' %>">

            <label for="cpf">CPF</label>
            <input id="cpf" name="cpf" type="text" required value="<%= form.cpf || '' %>">

            <label for="email">Email</label>
            <input id="email" name="email" type="email" required value="<%= form.email || '' %>">

            <label for="senha">Senha</label>
            <input id="senha" name="senha" type="password" required>

            <label for="role">Perfil</label>
            <select id="role" name="role" required>
                <option value="aluno" <%= form.role === 'aluno' ? 'selected' : '' %>>Aluno</option>
                <option value="professor" <%= form.role === 'professor' ? 'selected' : '' %>>Professor</option>
            </select>

            <button type="submit">Cadastrar</button>
        </form>

        <a href="/login" class="back-link">Voltar ao login</a>
    </div>
</body>
</html>
