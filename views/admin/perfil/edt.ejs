<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Meu Perfil</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../cabecario', { titulo: 'SkillUP - Editar Perfil' }) %>

    <div class="container">
        <h1>Editar Meu Perfil</h1>
        <form action="/admin/perfil/edt" method="post" enctype="multipart/form-data">
            <label for="nome">Nome</label>
            <input id="nome" name="nome" type="text" value="<%= usuario.nome %>" required>

            <label for="email">Email</label>
            <input id="email" name="email" type="email" value="<%= usuario.email %>" required>

            <label for="foto">Foto de perfil (arquivo)</label>
            <% if (usuario.foto) { %>
                <img src="<%= usuario.foto %>" alt="Foto atual" class="media-preview">
            <% } %>
            <input id="foto" name="foto" type="file" accept="image/*">

            <label for="telefone">Telefone</label>
            <input id="telefone" name="telefone" type="text" value="<%= usuario.telefone || '' %>">

            <label for="bio">Bio</label>
            <textarea id="bio" name="bio"><%= usuario.bio || '' %></textarea>

            <label for="senha">Nova senha (opcional)</label>
            <input id="senha" name="senha" type="password">

            <button class="btn" type="submit">Salvar Alteracoes</button>
            <a class="voltar" href="/admin/perfil">Cancelar</a>
        </form>
    </div>
</body>
</html>
