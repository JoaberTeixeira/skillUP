<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Perfil</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../cabecario', { titulo: 'SkillUP - Meu Perfil' }) %>

    <div class="container">
        <div class="perfil-topo">
            <div class="avatar">
                <% if (usuario.foto) { %>
                    <img src="<%= usuario.foto %>" alt="Foto de perfil">
                <% } else { %>
                    <span><%= usuario.nome ? usuario.nome.slice(0, 1) : 'U' %></span>
                <% } %>
            </div>
            <div>
                <h1><%= usuario.nome %></h1>
                <p class="perfil-role">Perfil: <strong><%= usuario.role %></strong></p>
            </div>
        </div>

        <div class="linha"><span class="label">Email:</span> <%= usuario.email %></div>
        <div class="linha"><span class="label">CPF:</span> <%= usuario.cpf %></div>
        <div class="linha"><span class="label">Telefone:</span> <%= usuario.telefone || 'Nao informado' %></div>
        <div class="linha"><span class="label">Bio:</span> <%= usuario.bio || 'Sem bio' %></div>

        <div class="acoes">
            <a href="/admin/perfil/edt" class="btn">Editar Meu Perfil</a>
        </div>
    </div>
</body>
</html>
