<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Postagem</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../cabecario', { titulo: 'SkillUP - sistema de aprendizagem' }) %>
    <div class="container">
        <h3>Editar Postagem</h3>

        <form action="/admin/postagem/edt/<%= postagem._id %>" method="post" enctype="multipart/form-data">
            <label>Autor:</label>
            <input type="text" value="<%= postagem.autorNome || 'Sem autor' %> (<%= postagem.autorRole || '-' %>)" readonly>

            <label for="titulo">Titulo:</label>
            <input type="text" id="titulo" name="titulo" value="<%= postagem.titulo %>" required>

            <label for="midia">Midia (imagem ou video):</label>
            <% if (postagem.midia) { %>
                <% const isVideo = /\.(mp4|webm|ogg)$/i.test(postagem.midia); %>
                <% if (isVideo) { %>
                    <video src="<%= postagem.midia %>" controls class="media-preview"></video>
                <% } else { %>
                    <img src="<%= postagem.midia %>" alt="Midia atual" class="media-preview">
                <% } %>
            <% } %>
            <input type="file" id="midia" name="midia" accept="image/*,video/*">

            <label for="descricao">Descricao:</label>
            <input type="text" id="descricao" name="descricao" value="<%= postagem.descricao %>" required>

            <label for="categoria">Categoria:</label>
            <select id="categoria" name="categoria" required>
                <option value="basquete" <%= postagem.categoria === 'basquete' ? 'selected' : '' %>>Basquete</option>
                <option value="volei" <%= postagem.categoria === 'volei' ? 'selected' : '' %>>Volei</option>
                <option value="futsal" <%= postagem.categoria === 'futsal' ? 'selected' : '' %>>Futsal</option>
                <option value="futebol" <%= postagem.categoria === 'futebol' ? 'selected' : '' %>>Futebol</option>
                <option value="handebol" <%= postagem.categoria === 'handebol' ? 'selected' : '' %>>Handebol</option>
                <option value="tenis" <%= postagem.categoria === 'tenis' ? 'selected' : '' %>>Tenis</option>
                <option value="futvolei" <%= postagem.categoria === 'futvolei' ? 'selected' : '' %>>Futvolei</option>
                <option value="volei de areia" <%= postagem.categoria === 'volei de areia' ? 'selected' : '' %>>Volei de Areia</option>
                <option value="padel" <%= postagem.categoria === 'padel' ? 'selected' : '' %>>Padel</option>
                <option value="outros esportes" <%= postagem.categoria === 'outros esportes' ? 'selected' : '' %>>Outros Esportes</option>
            </select>

            <button type="submit">Salvar</button>
        </form>

</body>

</html>
